{
  "name": "present-json",
  "version": "0.1.0",
  "description": "Chrome extension that renders JSON responses as user-templated HTML.",
  "private": true,
  "type": "module",
  "license": "MIT",
  "author": {
    "name": "Matt Altermatt",
    "email": "1435066+MattAltermatt@users.noreply.github.com",
    "url": "https://github.com/MattAltermatt"
  },
  "homepage": "https://github.com/MattAltermatt/present-json#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/MattAltermatt/present-json.git"
  },
  "bugs": {
    "url": "https://github.com/MattAltermatt/present-json/issues"
  },
  "keywords": [
    "chrome-extension",
    "mv3",
    "json",
    "json-viewer",
    "template",
    "devtool"
  ],
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "test": "TZ=UTC vitest run",
    "test:watch": "TZ=UTC vitest",
    "test:e2e": "playwright test",
    "fixtures": "node test/fixtures-server/run.mjs",
    "lint": "eslint --no-error-on-unmatched-pattern 'src/**/*.ts'",
    "format": "prettier --write 'src/**/*.{ts,html,json}'",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@crxjs/vite-plugin": "^2.0.0",
    "@playwright/test": "^1.48.0",
    "@types/chrome": "^0.0.270",
    "@types/node": "^20.11.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.57.0",
    "prettier": "^3.2.0",
    "typescript": "^5.4.0",
    "vite": "^5.2.0",
    "vitest": "^1.5.0"
  }
}
