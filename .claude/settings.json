{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/docs-liquid-check.sh"
          },
          {
            "type": "command",
            "command": "bash .claude/hooks/dist-stale-warning.sh"
          }
        ]
      }
    ]
  }
}
